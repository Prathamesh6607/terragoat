orm/aws/s3.tf"}, "region": {"startLine": 65, "endLine": 87, "snippet": {"text": "resource \"aws_s3_bucket\" \"operations\" {\n  # bucket is not encrypted\n  # bucket does not have access logs\n  bucket = \"${local.resource_prefix.value}-operations\"\n  acl    = \"private\"\n  versioning {\n    enabled = true\n  }\n  force_destroy = true\n  tags = merge({\n    Name        = \"${local.resource_prefix.value}-operations\"\n    Environment = local.resource_prefix.value\n    }, {\n    git_commit           = \"d68d2897add9bc2203a5ed0632a5cdd8ff8cefb0\"\n    git_file             = \"terraform/aws/s3.tf\"\n    git_last_modified_at = \"2020-06-16 14:46:24\"\n    git_last_modified_by = \"nimrodkor@gmail.com\"\n    git_modifiers        = \"nimrodkor\"\n    git_org              = \"bridgecrewio\"\n    git_repo             = \"terragoat\"\n    yor_trace            = \"29efcf7b-22a8-4bd6-8e14-1f55b3a2d743\"\n  })\n}\n"}}}}]}, {"ruleId": "CKV_AWS_144", "ruleIndex": 81, "level": "error", "attachments": [], "message": {"text": "Ensure that S3 bucket has cross-region replication enabled"}, "locations": [{"physicalLocation": {"artifactLocation": {"uri": "terraform/aws/s3.tf"}, "region": {"startLine": 113, "endLine": 141, "snippet": {"text": "resource \"aws_s3_bucket\" \"logs\" {\n  bucket = \"${local.resource_prefix.value}-logs\"\n  acl    = \"log-delivery-write\"\n  versioning {\n    enabled = true\n  }\n  server_side_encryption_configuration {\n    rule {\n      apply_server_side_encryption_by_default {\n        sse_algorithm     = \"aws:kms\"\n        kms_master_key_id = \"${aws_kms_key.logs_key.arn}\"\n      }\n    }\n  }\n  force_destroy = true\n  tags = merge({\n    Name        = \"${local.resource_prefix.value}-logs\"\n    Environment = local.resource_prefix.value\n    }, {\n    git_commit           = \"d68d2897add9bc2203a5ed0632a5cdd8ff8cefb0\"\n    git_file             = \"terraform/aws/s3.tf\"\n    git_last_modified_at = \"2020-06-16 14:46:24\"\n    git_last_modified_by = \"nimrodkor@gmail.com\"\n    git_modifiers        = \"nimrodkor\"\n    git_org              = \"bridgecrewio\"\n    git_repo             = \"terragoat\"\n    yor_trace            = \"01946fe9-aae2-4c99-a975-e9b0d3a4696c\"\n  })\n}\n"}}}}]}, {"ruleId": "CKV_AWS_144", "ruleIndex": 81, "level": "error", "attachments": [], "message": {"text": "Ensure that S3 bucket has cross-region replication enabled"}, "locations": [{"physicalLocation": {"artifactLocation": {"uri": "terraform/aws/s3.tf"}, "region": {"startLine": 89, "endLine": 111, "snippet": {"text": "resource \"aws_s3_bucket\" \"data_science\" {\n  # bucket is not encrypted\n  bucket = \"${local.resource_prefix.value}-data-science\"\n  acl    = \"private\"\n  versioning {\n    enabled = true\n  }\n  logging {\n    target_bucket = \"${aws_s3_bucket.logs.id}\"\n    target_prefix = \"log/\"\n  }\n  force_destroy = true\n  tags = {\n    git_commit           = \"d68d2897add9bc2203a5ed0632a5cdd8ff8cefb0\"\n    git_file             = \"terraform/aws/s3.tf\"\n    git_last_modified_at = \"2020-06-16 14:46:24\"\n    git_last_modified_by = \"nimrodkor@gmail.com\"\n    git_modifiers        = \"nimrodkor\"\n    git_org              = \"bridgecrewio\"\n    git_repo             = \"terragoat\"\n    yor_trace            = \"9a7c8788-5655-4708-bbc3-64ead9847f64\"\n  }\n}\n"}}}}]}, {"ruleId": "CKV2_AWS_62", "ruleIndex": 82, "level": "error", "attachments": [], "message": {"text": "Ensure S3 buckets should have event notifications enabled"}, "locations": [{"physicalLocation": {"artifactLocation": {"uri": "terraform/aws/ec2.tf"}, "region": {"startLine": 271, "endLine": 288, "snippet": {"text": "resource \"aws_s3_bucket\" \"flowbucket\" {\n  bucket        = \"${local.resource_prefix.value}-flowlogs\"\n  force_destroy = true\n\n  tags = merge({\n    Name        = \"${local.resource_prefix.value}-flowlogs\"\n    Environment = local.resource_prefix.value\n    }, {\n    git_commit           = \"d68d2897add9bc2203a5ed0632a5cdd8ff8cefb0\"\n    g